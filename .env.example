# Required: your own OpenAI API key (this project makes real API calls, billed to this key)
OPENAI_API_KEY=your-api-key

# Optional: OpenAI model used for both the extraction step and the response-drafting step.
# Defaults to gpt-5.4-mini if unset. Use gpt-5.4-nano for an even cheaper/faster run.
OPENAI_MODEL=openai/gpt-5.4-mini
